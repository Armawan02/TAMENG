{
  "entities": {
    "alert": {
      "title": "Alert",
      "description": "Represents a community alert about a scam or digital manipulation.",
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["Tinggi", "Sedang", "Rendah"],
          "description": "Risk level of the alert."
        },
        "title": {
          "type": "string",
          "description": "Title of the alert."
        },
        "desc": {
          "type": "string",
          "description": "Description of the scam or manipulation."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the alert was reported."
        },
        "reportsCount": {
          "type": "number",
          "description": "Number of users who reported this."
        }
      },
      "required": ["type", "title", "desc", "createdAt", "reportsCount"]
    }
  },
  "firestore": {
    "alerts/{alertId}": {
      "schema": "alert",
      "description": "Store alerts reported by the community."
    }
  }
}
